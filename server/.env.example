# =============================================
# Configuración del servidor ERP — Backend
# =============================================
# Copia este archivo como .env y llena los valores reales.
# NUNCA commitas el archivo .env al repositorio.

# Base de datos (Neon Postgres en producción, local en desarrollo)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/ERP_def

# Puerto del servidor (default: 4000)
PORT=4000

# JWT — usa un string largo y aleatorio en producción (mínimo 32 chars)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio-en-produccion

# URL del frontend en producción (para CORS). Ejemplo: https://tu-app.vercel.app
FRONTEND_URL=

# Contraseña inicial que se asigna a los nuevos empleados al crearlos
# El administrador debe indicarles que la cambien en su primer ingreso
DEFAULT_EMPLOYEE_PASSWORD=Bienvenido1!

# Entorno (development | production)
NODE_ENV=development
